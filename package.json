{
  "name": "seo-pages",
  "version": "1.0.0",
  "description": "Programmatic SEO page generator",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "seo": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'"
  },
  "keywords": [
    "seo",
    "static-site-generator",
    "programmatic-seo"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "js-yaml": "^4.1.1",
    "markdown-it": "^14.1.1",
    "nunjucks": "^3.2.4",
    "picocolors": "^1.1.1",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.0",
    "@types/nunjucks": "^3.2.6",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
