{% extends "layout.njk" %}

{% block content %}
<section class="hero">
  <h1>{{ page.title }}</h1>
  <p class="hero-description">{{ page.description }}</p>
</section>

{% for name, html in page.content %}
<section class="content-block content-block--{{ name }}">
  {{ html | safe }}
</section>
{% endfor %}

{% if page.internalLinks.length > 0 %}
<section class="related-pages">
  <h2>Related Pages</h2>
  <ul>
    {% for link in page.internalLinks %}
    <li><a href="{{ link.targetUrl }}">{{ link.anchorText }}</a></li>
    {% endfor %}
  </ul>
</section>
{% endif %}
{% endblock %}
